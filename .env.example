# Atlassian site subdomain (e.g. "mycompany" for mycompany.atlassian.net)
JIRA_SITE=

# Email address associated with the scoped token
JIRA_EMAIL=

# Scoped access token (create at https://id.atlassian.com/manage-profile/security/api-tokens)
# Required scopes: read:jira-work, write:jira-work
JIRA_SCOPED_TOKEN=

# Cloud ID (leave blank to auto-discover — set to skip a network round-trip)
JIRA_CLOUD_ID=

# ── Smoke test config ────────────────────────────────────────────
# Project key to use for smoke test (must exist in your JIRA instance)
SMOKE_TEST_PROJECT=
